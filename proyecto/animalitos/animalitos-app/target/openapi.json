int32","description":"Nueva edad en años (0-100).","example":7,"maximum":100,"minimum":0}},"required":["edad","especie"]},"Animal":{"type":"object","description":"Animal tal y como lo expone la API.","properties":{"id":{"type":"string","description":"Identificador publico (UUID).","example":"5b3f1d2a-7c0d-4d8a-9b8e-2c6c1f0aafee"},"nombre":{"type":"string","description":"Nombre del animal.","example":"Lucas"},"especie":{"type":"string","description":"Especie del animal.","enum":["PERRO","GATO","HAMSTER","CONEJO","LORO","PEZ","TORTUGA"],"example":"GATO"},"edad":{"type":"integer","format":"int32","description":"Edad en años.","example":3,"maximum":100,"minimum":0}}},"ErrorResponse":{"type":"object","description":"Estructura uniforme de error devuelta por la API.","properties":{"timestamp":{"type":"string","format":"date-time","description":"Instante en que se produjo el error (ISO-8601).","example":"2026-04-27T16:00:00Z"},"status":{"type":"integer","format":"int32","description":"Codigo HTTP.","example":404},"error":{"type":"string","description":"Identificador del tipo de error.","example":"ANIMAL_NO_ENCONTRADO"},"mensaje":{"type":"string","description":"Mensaje legible para el cliente.","example":"No existe animal con id ..."},"detalles":{"type":"array","description":"Detalles de validacion campo a campo (puede ser vacio).","items":{"$ref":"#/components/schemas/ValidationErrorDTO"}}}},"ValidationErrorDTO":{"type":"object","properties":{"campo":{"type":"string"},"mensaje":{"type":"string"}}},"CrearAnimalRequest":{"type":"object","description":"Datos para crear un animal nuevo.","properties":{"nombre":{"type":"string","description":"Nombre unico del animal (2-60 caracteres).","example":"Lucas"},"especie":{"type":"string","description":"Especie del animal.","enum":["PERRO","GATO","HAMSTER","CONEJO","LORO","PEZ","TORTUGA"],"example":"GATO"},"edad":{"type":"integer","format":"int32","description":"Edad en años (0-100).","example":3,"maximum":100,"minimum":0}},"required":[