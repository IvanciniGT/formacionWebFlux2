{"openapi":"3.1.0","info":{"title":"Animalitos API","description":"API CRUD para la gestion de animalitos. Contrato publico documentado con OpenAPI 3.","contact":{"name":"Equipo Animalitos","email":"animalitos@curso.com"},"license":{"name":"Apache 2.0","url":"https://www.apache.org/licenses/LICENSE-2.0"},"version":"1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Local"}],"tags":[{"name":"Animalitos","description":"API CRUD de animalitos. Identificadores publicos en formato UUID."}],"paths":{"/api/v1/animalitos/{id}":{"get":{"tags":["Animalitos"],"summary":"Recuperar un animal por id","description":"Devuelve el animal cuyo identificador publico (UUID) coincide con el proporcionado.","operationId":"getAnimal","parameters":[{"name":"id","in":"path","description":"Identificador publico (UUID) del animal","required":true,"schema":{"type":"string"},"example":"5b3f1d2a-7c0d-4d8a-9b8e-2c6c1f0aafee"}],"responses":{"200":{"description":"Animal encontrado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/Animal"}}}},"404":{"description":"No existe animal con ese id","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}},"put":{"tags":["Animalitos"],"summary":"Modificar un animal","description":"Modifica especie y edad. El nombre NO se puede modificar.","operationId":"updateAnimal","parameters":[{"name":"id","in":"path","description":"Identificador publico (UUID) del animal a modificar","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ModificarAnimalRequest"}}},"required":true},"responses":{"200":{"description":"Animal modificado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/Animal"}}}},"400":{"description":"Datos invalidos (validacion)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"No existe animal con ese id","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}},